# Discord Bot Token
# Obtain from https://discord.com/developers/applications
DISCORD_TOKEN=

# Groq API Key
# Obtain from https://console.groq.com/keys
GROQ_API_KEY=

# Instagram Long-Lived Page Access Token
# Requires: instagram_content_publish, instagram_basic, pages_read_engagement scopes
# Obtain via Meta App Dashboard (Business or Creator account required)
INSTAGRAM_ACCESS_TOKEN=

# Instagram Professional Account User ID
# Found in Instagram Graph API: GET /me?fields=id
INSTAGRAM_BUSINESS_ID=

# Amazon Associates affiliate tag (store ID)
AMAZON_AFFILIATE_TAG=metechs-21

# Metechs website product API endpoint
# Defaults to https://metechs-store.vercel.app/api/products/public if not set
WEBSITE_API_URL=https://metechs-store.vercel.app/api/products/public

# Metechs website API key (reserved for future authenticated endpoints)
WEBSITE_API_KEY=
